# ─────────────────────────────────────────────────────────────────────────
# market-microstructure-engine — .gitignore
# Rule of thumb: source, docs, and ops scripts are tracked. Anything that is
# generated, runtime state, or secret is NOT.
# ─────────────────────────────────────────────────────────────────────────

# ── Build artifacts (CMake out-of-source) ───────────────────────────────
build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe

# ── Runtime state ─────────────────────────────────────────────────────────
run/                 # PID files
logs/*.log
logs/*.log.*         # spdlog rotations (engine.1.log, engine.2.log, ...)
logs/*.out
logs/*.err
*.pid

# ── Market data / databases (ground-truth, regenerated by the engine) ─────
data/*.db
data/*.db-shm
data/*.db-wal
data/*.sqlite
data/*.sqlite3

# ── Secrets — NEVER commit ──────────────────────────────────────────────
config/api_key.txt
ops/.env
.env
*.pem
*.key
confirm_live_trading.txt   # the live-trading tripwire file must never be tracked

# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# ── OS / editor cruft ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# ── Claude Code local (personal) settings ────────────────────────────────
.claude/settings.local.json

# ─────────────────────────────────────────────────────────────────────────
# Intentionally TRACKED (do not ignore — they are portfolio/showcase output):
#   reports/snapshots/*.txt          sample backtest + health snapshots
#   agent/hermes/reports/*.md        sample daily intelligence reports
#   docs/*.md, ops/*.sh, ops/*.py    operations layer
#   ops/.env.example                 template, safe to commit
# ─────────────────────────────────────────────────────────────────────────
