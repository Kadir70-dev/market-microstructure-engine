# Copy to ops/.env and fill in. ops/.env is gitignored.
# All values are optional — scripts degrade gracefully if any are unset.

# TwelveData API key. If set, start_engine.sh writes it to config/api_key.txt
# at startup. If unset, scripts fall back to whatever is already in that file.
TWELVEDATA_API_KEY=

# Telegram notifications (infra only — start/stop/crash, never trading).
# Create a bot via @BotFather, get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Session schedule (UTC, 24-hour HH:MM). Used by ops/run_session.sh and
# crontab.example to decide when to start and stop the engine each day.
LONDON_OPEN_UTC=07:00
NY_CLOSE_UTC=21:00

# How long status checks/health probes will tolerate log silence (seconds).
# Engine cycle is 30s, so 120s = 4 missed cycles before we flag stale.
STALE_LOG_THRESHOLD_S=120
